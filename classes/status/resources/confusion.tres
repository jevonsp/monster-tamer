[gd_resource type="Resource" script_class="StatusData" format=3 uid="uid://cm911937hvpd9"]

[ext_resource type="Script" uid="uid://blx4fyq45fja3" path="res://3d_migration/battle_action/action.gd" id="1_action"]
[ext_resource type="Script" uid="uid://bvgeyvppx7tph" path="res://classes/status/status_data.gd" id="2_status"]
[ext_resource type="Script" uid="uid://18gkypu1dgxy" path="res://3d_migration/battle_action/action_list.gd" id="3_list"]
[ext_resource type="Script" uid="uid://tdzrwp1dhoscy" path="res://3d_migration/battle_action/actions/set_substitute_action_list.gd" id="4_sub"]
[ext_resource type="Script" uid="uid://941llsbe6qozm" path="res://3d_migration/battle_action/actions/tick_statuses_action.gd" id="5_tick"]
[ext_resource type="Resource" uid="uid://i0k0cpyy3spch" path="res://classes/status/resources/confusion_self_hit.tres" id="6_self_hit"]

[sub_resource type="Resource" id="Resource_conf_sub"]
